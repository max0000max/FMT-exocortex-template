{
  "mcpServers": {

    "knowledge-mcp": {
      "command": "npx",
      "args": ["-y", "--prefer-offline", "{{KNOWLEDGE_MCP_PACKAGE}}"],
      "env": {
        "DATABASE_URL": "{{KNOWLEDGE_MCP_DATABASE_URL}}",
        "USER_ID": "max0000max"
      }
    },

    "digital-twin-mcp": {
      "command": "npx",
      "args": ["-y", "--prefer-offline", "{{DIGITAL_TWIN_MCP_PACKAGE}}"],
      "env": {
        "DATABASE_URL": "{{DIGITAL_TWIN_DATABASE_URL}}",
        "USER_ID": "max0000max"
      }
    }

  }
}
